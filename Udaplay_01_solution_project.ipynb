class VectorStoreManager:
    def __init__(self, persist_dir="chroma_db"):
        self.client = chromadb.Client(
            chromadb.config.Settings(persist_directory=persist_dir)
        )

        self.embedding_function = embedding_functions.SentenceTransformerEmbeddingFunction(
            model_name="all-MiniLM-L6-v2"
        )

        self.collection = self.client.get_or_create_collection(
            name="games",
            embedding_function=self.embedding_function
        )

    def add_documents(self, docs):
        for i, doc in enumerate(docs):
            self.collection.add(
                documents=[doc["text"]],
                metadatas=[doc["metadata"]],
                ids=[str(i)]
            )

    def query(self, query_text, n_results=3):
        return self.collection.query(
            query_texts=[query_text],
            n_results=n_results
        )

def load_game_data(path="data/*.json"):
    files = glob.glob(path)
    documents = []

    for file in files:
        with open(file, "r") as f:
            data = json.load(f)

            text = f"""
            Title: {data.get('title')}
            Developer: {data.get('developer')}
            Publisher: {data.get('publisher')}
            Release Date: {data.get('release_date')}
            Platforms: {', '.join(data.get('platforms', []))}
            Genre: {data.get('genre')}
            Description: {data.get('description', '')}
            """

            documents.append({
                "text": text,
                "metadata": data
            })

    return documents

vs = VectorStoreManager()

docs = load_game_data()
vs.add_documents(docs)

print("✅ Data embedded into ChromaDB")

query = "Who developed FIFA 21?"

results = vs.query(query)

print("🔍 Retrieved Documents:\n")
