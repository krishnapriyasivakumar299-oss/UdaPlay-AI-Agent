import os
import re
from openai import OpenAI
from tavily import TavilyClient
from dotenv import load_dotenv

load_dotenv()

client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
tavily = TavilyClient(api_key=os.getenv("TAVILY_API_KEY"))

from chromadb.utils import embedding_functions
import chromadb

class VectorStoreManager:
    def __init__(self, persist_dir="chroma_db"):
        self.client = chromadb.Client(
            chromadb.config.Settings(persist_directory=persist_dir)
        )

        self.embedding_function = embedding_functions.SentenceTransformerEmbeddingFunction(
            model_name="all-MiniLM-L6-v2"
        )

        self.collection = self.client.get_or_create_collection(
            name="games",
            embedding_function=self.embedding_function
        )

    def query(self, query_text, n_results=3):
        return self.collection.query(
            query_texts=[query_text],
            n_results=n_results
        )

vs = VectorStoreManager()

def retrieve_game(query):
    return vs.query(query)

def evaluate_retrieval(query, retrieved_docs):
    prompt = f"""
    Query: {query}
    Data: {retrieved_docs}

    Is this sufficient to answer?
    Return:
    Confidence: (0-1)
    Verdict: YES or NO
    """

    response = client.chat.completions.create(
        model="gpt-4.1-mini",
        messages=[{"role": "user", "content": prompt}]
    )

    return response.choices[0].message.content

def game_web_search(query):
    return tavily.search(query=query, max_results=3)

def extract_confidence(text):
    match = re.search(r"Confidence:\s*(\d\.\d+)", text)
    return float(match.group(1)) if match else 0.0

class UdaPlayAgent:
    def __init__(self):
        self.memory = []

    def generate_answer(self, query, data):
        prompt = f"""
        Answer clearly and structured.

        Question: {query}
        Data: {data}
        """

        response = client.chat.completions.create(
            model="gpt-4.1-mini",
            messages=[{"role": "user", "content": prompt}]
        )

        return response.choices[0].message.content

    def run(self, query):
        print("\n===== NEW QUERY =====")
        print("STATE: RETRIEVE")

        retrieved = retrieve_game(query)

        print("STATE: EVALUATE")
        evaluation = evaluate_retrieval(query, retrieved)
        print(evaluation)

        confidence = extract_confidence(evaluation)

        if confidence > 0.7:
            print("STATE: ANSWER FROM RAG")
            answer = self.generate_answer(query, retrieved)
            source = "Local DB"
        else:
            print("STATE: WEB SEARCH")
            web_data = game_web_search(query)

            self.memory.append(web_data)

            answer = self.generate_answer(query, web_data)
            source = "Web"

        return {
            "query": query,
            "answer": answer,
            "confidence": confidence,
            "source": source
        }

agent = UdaPlayAgent()

queries = [
    "Who developed FIFA 21?",
    "When was God of War Ragnarok released?",
    "What platform was Pokemon Red launched on?"
]

for q in queries:
    result = agent.run(q)
    print("\n🎮 FINAL OUTPUT:")
    print(result)
